.DS_Store

# Dependencies
node_modules/

# Yarn (Berry, node-modules linker; yarn itself comes from Corepack)
.yarn/*
!.yarn/patches
!.yarn/sdks
!.yarn/versions
.pnp.*

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local environment files
.env
.env.*
!.env.example

# OS and editor noise
Thumbs.db
.idea/
.vscode/

# Build and coverage output
dist/
build/
coverage/

# Local archives
*.zip
*.tar
*.tar.gz

# TASK-008 raw Công báo downloads: 36MB of `.doc` binaries + the tokened landing
# page. The parsed, durable extract under research/task-008-congbao-loader/out/ is
# committed instead, so the loader runs offline even after the download tokens expire.
research/task-008-congbao-loader/doc/
research/task-008-congbao-loader/page.html

# FTA raw Công báo downloads (hundreds of MB of `.doc`/`.docx` + tokened pages).
# The parsed extracts (research/fta-loader/*/rows.ndjson) are committed instead.
research/fta-loader/*/doc/
research/fta-loader/*/page.html

# Research extract outputs are regeneratable via the parsers; the CANONICAL,
# committed copies live in db/seed/data/. Keep the proof code + READMEs, not the
# large regenerated .ndjson under research/.
research/task-008-congbao-loader/out/
research/fta-loader/*/rows.ndjson

# Legal RAG raw Công báo downloads (.doc binaries + tokened content pages). The
# parsed extract under db/seed/data/legal/*.ndjson is committed instead, so the
# loader runs offline after the download tokens expire (same as TASK-008).
research/legal-loader/doc/
research/legal-loader/*.page.html
research/legal-loader/page.html
research/legal-loader/out/

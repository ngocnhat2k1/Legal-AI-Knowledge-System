# PostgreSQL connection string, used by both the API and the migrate step.
# Host "db" is the docker-compose service name. For a local (non-Docker) run,
# point it at your own Postgres, e.g. postgres://app:app@localhost:5432/customs_assistant
DATABASE_URL=postgres://app:app@db:5432/customs_assistant

# Port the API listens on.
PORT=3000
